{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",               // Keep modern ESM syntax
    "moduleResolution": "Node",       // <-- Node resolver, no .js required
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],

    // Path alias (optional, avoids long relative paths)
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}